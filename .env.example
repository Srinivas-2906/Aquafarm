# Database
DATABASE_URL=postgresql://aqualedger:aqualedger@localhost:5432/aqualedger?schema=public

# API
API_PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CORS_ORIGIN=http://localhost:5173
COOKIE_SECURE=false
SWAGGER_ENABLED=true
DEBUG_ENABLED=true
AUTH_ACTIVATION_ENABLED=true
AUTH_OTP_ENABLED=true

# Web
VITE_API_URL=http://localhost:3001

# OTP (development mock)
OTP_MOCK_ENABLED=true
OTP_MOCK_CODE=123456
